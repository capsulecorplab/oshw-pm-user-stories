n":{"start":{"line":12,"column":1,"offset":118},"end":{"line":12,"column":20,"offset":137},"indent":[]},"xvault":false,"to":{"fname":"3-user-stories"}},{"from":{"fname":"root","vaultName":"user-stories"},"type":"backlink","position":{"start":{"line":6,"column":4,"offset":326},"end":{"line":6,"column":18,"offset":340},"indent":[]},"value":"0-workshop","alias":"0-workshop"},{"from":{"fname":"root","vaultName":"user-stories"},"type":"backlink","position":{"start":{"line":10,"column":1,"offset":372},"end":{"line":10,"column":16,"offset":387},"indent":[]},"value":"0-workshop"}],"anchors":{"1-audience-survey":{"type":"header","text":"1-audience-survey","value":"1-audience-survey","line":8,"column":0,"depth":2},"2-a-better-way":{"type":"header","text":"2-a-better-way","value":"2-a-better-way","line":12,"column":0,"depth":2},"3-user-stories":{"type":"header","text":"3-user-stories","value":"3-user-stories","line":16,"column":0,"depth":2}},"children":[],"parent":"grm72euar5jvm3g7039hzc9","data":{}},"body":"<h1 id=\"0-workshop\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#0-workshop\"></a>0. Workshop</h1>\n<h2 id=\"1-audience-survey\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#1-audience-survey\"></a><a href=\"/notes/py9pnyni5n8iwwbgqmfsad1\">1. Audience Survey</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">1. Audience Survey</span></div>\n<a href=\"/notes/py9pnyni5n8iwwbgqmfsad1\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><h2 id=\"questions\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#questions\"></a>Questions</h2>\n<p><a href=\"/notes/vatakntmpixw8trhk0j7d18\">Q1. How many people here have released a OSHW project? (x1/y)</a></p>\n<p><a href=\"/notes/gw1yukq3xe1gbwxk6hvoz36\">Q2. How many of you have certified any of those projects? (x2/x1)</a></p>\n<p><a href=\"/notes/hmsq2kbj4iv67nkjubl4ll1\">Q3. Have any of you certified multiple projects? (x3/x2)</a></p>\n<p><a href=\"/notes/ofgqlh3kps5au9p5ltkszo5\">Q4. How many of you have re-certified updated releases of certified projects? (x4/x2)</a></p>\n<p><a href=\"/notes/yasz8z5tj5sx7msifvx0g3v\">Q5. Has anyone tried modifying or building on top of existing projects? (x5/y)</a></p>\n<h2 id=\"summary\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#summary\"></a>Summary</h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Q1. How many people here have released a OSHW project? (x1/y)</span></div>\n<a href=\"/notes/vatakntmpixw8trhk0j7d18\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><h2 id=\"notes\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#notes\"></a>notes</h2>\n<ul>\n<li>(example projects from audience)</li>\n<li>(experience from audience, \"how did that go?\")</li>\n</ul>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Q2. How many of you have certified any of those projects? (x2/x1)</span></div>\n<a href=\"/notes/gw1yukq3xe1gbwxk6hvoz36\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><h2 id=\"notes-1\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#notes-1\"></a>notes</h2>\n<ul>\n<li>(example projects from audience)</li>\n<li>(experience from audience, \"how did that go?\")</li>\n</ul>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Q3. Have any of you certified multiple projects? (x3/x2)</span></div>\n<a href=\"/notes/hmsq2kbj4iv67nkjubl4ll1\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><h2 id=\"notes-2\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#notes-2\"></a>notes</h2>\n<ul>\n<li>(example projects from audience)</li>\n<li>(experience from audience, \"how did that go?\")</li>\n</ul>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Q4. How many of you have re-certified updated releases of certified projects? (x4/x2)</span></div>\n<a href=\"/notes/ofgqlh3kps5au9p5ltkszo5\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><h2 id=\"notes-3\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#notes-3\"></a>notes</h2>\n<ul>\n<li>(example projects from audience)</li>\n<li>(experience from audience, \"how did that go?\")</li>\n</ul>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Q5. Has anyone tried modifying or building on top of existing projects? (x5/y)</span></div>\n<a href=\"/notes/yasz8z5tj5sx7msifvx0g3v\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><h2 id=\"notes-4\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#notes-4\"></a>notes</h2>\n<ul>\n<li>(example projects from audience)</li>\n<li>(specific experiences from audience, \"what project(s) did you make/modify/reuse?\")</li>\n</ul>\n</div></div><p></p><p></p>\n</div></div><p></p><p></p>\n<h2 id=\"2-there-must-be-a-better-way\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#2-there-must-be-a-better-way\"></a><a href=\"/notes/x9z2rffos85uyh5a7c1xmh2\">2. There Must Be a Better Way</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">2. There Must Be a Better Way</span></div>\n<a href=\"/notes/x9z2rffos85uyh5a7c1xmh2\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><h2 id=\"1-core-capabilities\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#1-core-capabilities\"></a><a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">1. Core Capabilities</span></div>\n<a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>These are the core needs of the OSHW community when sharing, communicating, and collaborating on OSHW projects</p>\n<h2 id=\"1-oshw-definition\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#1-oshw-definition\"></a><a href=\"/notes/wnfhk1lyrz6r56si1p87dy3\">1. OSHW Definition</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">1. OSHW Definition</span></div>\n<a href=\"/notes/wnfhk1lyrz6r56si1p87dy3\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>OSHW projects should be developed and shared in accordance to the OSHW Definition.<sup><a href=\"#oshwdef\">1</a></sup></p>\n<p><a name=\"oshwdef\">1</a>: <a href=\"https://www.oshwa.org/definition/\">https://www.oshwa.org/definition/</a></p>\n</div></div><p></p><p></p>\n<h2 id=\"2-oshw-certification\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#2-oshw-certification\"></a><a href=\"/notes/unj23tn51l1huf1t5dl1akx\">2. OSHW Certification</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">2. OSHW Certification</span></div>\n<a href=\"/notes/unj23tn51l1huf1t5dl1akx\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>OSHW projects should be developed and shared in accordance to the OSHW Certification process.<sup><a href=\"#oshwcert\">1</a></sup></p>\n<p><a name=\"oshwcert\">1</a>: <a href=\"https://certification.oshwa.org/process.html\">https://certification.oshwa.org/process.html</a></p>\n</div></div><p></p><p></p>\n<h2 id=\"3-oshw-should-be-like-oss\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#3-oshw-should-be-like-oss\"></a><a href=\"/notes/m82kets1w41kkt4tn1xkkne\">3. OSHW Should Be like OSS</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">3. OSHW Should Be like OSS</span></div>\n<a href=\"/notes/m82kets1w41kkt4tn1xkkne\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>OSHW should be like Open Source Software (OSS) to the greatest degree possible (e.g. sharing, development, licensing).</p>\n</div></div><p></p><p></p>\n<h2 id=\"4-oshw-development-should-leverage-modern-software-development-techniques\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#4-oshw-development-should-leverage-modern-software-development-techniques\"></a><a href=\"/notes/mpi2r94umzmv4nh73f5vrrj\">4. OSHW Development Should Leverage Modern Software Development Techniques</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">4. OSHW Development Should Leverage Modern Software Development Techniques</span></div>\n<a href=\"/notes/mpi2r94umzmv4nh73f5vrrj\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>OSHW development should leverage modern software development techniques to improve the OSHW developer experience.</p>\n<h2 id=\"examples\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#examples\"></a>examples</h2>\n<ul>\n<li>package management</li>\n<li>DevOps (e.g., DevSecOps, DocOps)</li>\n<li>mono-repos</li>\n<li>design patterns (e.g., model-view-controller)</li>\n<li>semantic versioning</li>\n</ul>\n</div></div><p></p><p></p>\n</div></div><p></p><p></p>\n<h2 id=\"2-pillars\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#2-pillars\"></a><a href=\"/notes/6k53zfadywhww1r26lbeykt\">2. Pillars</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">2. Pillars</span></div>\n<a href=\"/notes/6k53zfadywhww1r26lbeykt\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>Classes of data that need to be captured <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a></p>\n<h2 id=\"1-bom-data\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#1-bom-data\"></a><a href=\"/notes/6sd4i7px8r6jw9dh71v3558\">1. BOM Data</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">1. BOM Data</span></div>\n<a href=\"/notes/6sd4i7px8r6jw9dh71v3558\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>Bill of Materials (BOM) data: list of components and counts covering all parts and tools which must be procured to build the project</p>\n</div></div><p></p><p></p>\n<h2 id=\"2-instructions\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#2-instructions\"></a><a href=\"/notes/82gydxsntjujxngqxqi6oj4\">2. Instructions</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">2. Instructions</span></div>\n<a href=\"/notes/82gydxsntjujxngqxqi6oj4\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><ul>\n<li>Assembly Instructions: complete list of instructions to build the project from its procured parts</li>\n<li>Operating Instructions: complete list of instructions to use the project safely and effectively</li>\n</ul>\n</div></div><p></p><p></p>\n<h2 id=\"3-supporting-data\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#3-supporting-data\"></a><a href=\"/notes/coywdnas48vrbabx52jz7b3\">3. Supporting Data</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">3. Supporting Data</span></div>\n<a href=\"/notes/coywdnas48vrbabx52jz7b3\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>e.g. design files,</p>\n<ul>\n<li>CAD models (e.g., Mechanical CAD files, PCB Gerbers files)</li>\n<li>Specifications (e.g., operating temperature range)</li>\n<li>Interface definitions (e.g., board pinout)</li>\n<li>Schematics (e.g., Circuit boards)</li>\n</ul>\n</div></div><p></p><p></p>\n</div></div><p></p><p></p>\n</div></div><p></p><p></p>\n<h2 id=\"3-developing-user-stories\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#3-developing-user-stories\"></a><a href=\"/notes/8655o7b563qlvdmr8bh7reg\">3. Developing User Stories</a></h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">3. Developing User Stories</span></div>\n<a href=\"/notes/8655o7b563qlvdmr8bh7reg\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>See also <a href=\"/notes/vnicpusapaldjc73aqtivy0\">User Story</a> template.</p>\n<h2 id=\"user-stories\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#user-stories\"></a>User Stories</h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">User Stories List</span></div>\n<a href=\"/notes/dvx35bxeck5zhnbvh5o4xq3\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">User Build an OSHW Project</span></div>\n<a href=\"/notes/oc31cidp5sb697ncgcwtzrx\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>As a <a href=\"/notes/fxz8p3n6c85t1vv7zdzzh35\">OSHW User</a>,\nI want to <a href=\"/notes/0ip40ulgkzaq74x6gu4o1lv\">Build an OSHW Project</a>,\nso that I can <a href=\"/notes/idtrtdfnouzj2xnmpxf8k7a\">Reproduce the OSHW Project</a></p>\n<p>related to <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a>: <a href=\"/notes/wnfhk1lyrz6r56si1p87dy3\">1. OSHW Definition</a></p>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Developer Organize Projects</span></div>\n<a href=\"/notes/gcx7j3slce2kb38rqjy05xs\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>As a <a href=\"/notes/1xociqysd5w7rdc48axj3av\">OSHW Developer</a>,\nI want to <a href=\"/notes/1kvgwkmiz5a5io62r6ledhy\">Organize OSHW Projects</a>,\nso that I can <a href=\"/notes/hjyjk8901dv9vd4asha9pha\">Conform to DRY Principle</a></p>\n<p>related to <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a>: <a href=\"/notes/mpi2r94umzmv4nh73f5vrrj\">4. OSHW Development Should Leverage Modern Software Development Techniques</a></p>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Developer Decompose Project</span></div>\n<a href=\"/notes/bdlqteih3cytl4ahfyl48og\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>As a <a href=\"/notes/1xociqysd5w7rdc48axj3av\">OSHW Developer</a>,\nI want to <a href=\"/notes/aedk9sv80dvcrjnqyhz1owp\">Decompose OSHW Project into Subprojects</a>,\nso that I can <a href=\"/notes/khfxtqov28cwoovn3gpqzge\">Identify Reusable Elements of a Project</a></p>\n<p>related to <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a>: <a href=\"/notes/mpi2r94umzmv4nh73f5vrrj\">4. OSHW Development Should Leverage Modern Software Development Techniques</a></p>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Developer Reuse Elements of External Projects</span></div>\n<a href=\"/notes/gsrjh2z5wb4nysbflzwn0ts\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>As a <a href=\"/notes/1xociqysd5w7rdc48axj3av\">OSHW Developer</a>,\nI want to <a href=\"/notes/lrr1qfd6wcco8q8e3oue4km\">Reuse Elements of External OSHW Projects</a>,\nso that I can <a href=\"/notes/di2bw8vuxhe07whffww3q9b\">Build upon Previous Engineering Effort</a></p>\n<p>related to <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a>: <a href=\"/notes/mpi2r94umzmv4nh73f5vrrj\">4. OSHW Development Should Leverage Modern Software Development Techniques</a></p>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Developer Reuse Elements of This Project</span></div>\n<a href=\"/notes/75ssft5a3d4zge2al7kydic\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>As a <a href=\"/notes/1xociqysd5w7rdc48axj3av\">OSHW Developer</a>,\nI want to <a href=\"/notes/4syyoeef0x2dl42o6cxwfig\">Reuse Elements of This OSHW Project</a>,\nso that I can <a href=\"/notes/a2r6p3tcgas7kxeh84alona\">Define an Element of a Project Only Once</a></p>\n<p>related to <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a>: <a href=\"/notes/mpi2r94umzmv4nh73f5vrrj\">4. OSHW Development Should Leverage Modern Software Development Techniques</a></p>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">User Fork an OSHW Project</span></div>\n<a href=\"/notes/9fgrfzpuolrfuzovbk18w25\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>As a <a href=\"/notes/fxz8p3n6c85t1vv7zdzzh35\">OSHW User</a>,\nI want to <a href=\"/notes/6guks59bqne12hcb5yga8op\">Fork an OSHW Project</a>,\nso that I can <a href=\"/notes/d23jvu0gxgygvb3jqk973ih\">Customize the Forked OSHW Project</a></p>\n<p>related to <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a>: <a href=\"/notes/m82kets1w41kkt4tn1xkkne\">3. OSHW Should Be like OSS</a></p>\n</div></div><p></p><p></p>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Developer Automate Certification</span></div>\n<a href=\"/notes/htrh9qkz97dr05c8lq6ioi7\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p>As a <a href=\"/notes/1xociqysd5w7rdc48axj3av\">OSHW Developer</a>,\nI want to <a href=\"/notes/z3esa6d0s7y1ksnl2pr0uzv\">Automate Certification</a>,\nso that I can <a href=\"/notes/0358acrsau9so23yx3tcxh5\">Easily Certify Every Release</a></p>\n<p>related to <a href=\"/notes/gxt00gigj1vgfc9gayv9q1o\">1. Core Capabilities</a>: <a href=\"/notes/unj23tn51l1huf1t5dl1akx\">2. OSHW Certification</a></p>\n</div></div><p></p><p></p>\n</div></div><p></p><p></p>\n<h2 id=\"users\"><a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#users\"></a>Users</h2>\n<p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">Users List</span></div>\n<a href=\"/notes/7d3hv9b0hklsmmog8ng98ql\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"portal-parent-fader-bottom\"></div><p></p><p></p><div class=\"portal-container\">\n<div class=\"portal-head\">\n<div class=\"portal-backlink\">\n<div class=\"portal-title\">From <span class=\"portal-text-title\">OSHW User</span></div>\n<a href=\"/notes/fxz8p3n6c85t1vv7zdzzh35\" class=\"portal-arrow\">Go to text <span class=\"right-arrow\">→</span></a>\n</div>\n</div>\n<div id=\"portal-parent-anchor\" class=\"portal-parent\" markdown=\"1\">\n<div class=\"portal-parent-fader-top\"></div>\n<div class=\"po